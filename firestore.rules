rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garante que o campo `role` não está sendo alterado nesta escrita.
    // request.resource.data = como o doc VAI ficar; resource.data = como ele ESTÁ hoje.
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    // Membro somente-leitura de um painel: o perfil do usuário logado aponta
    // (via panelOwnerId) para o dono `userId`. Custa um get(), por isso fica
    // sempre à direita dos || — isOwner/isAdmin resolvem primeiro.
    function isMember(userId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('panelOwnerId', '') == userId;
    }

    // Impede que o usuário comum se vincule/troque de painel sozinho num update.
    // Só o admin grava panelOwnerId (ao convidar um membro). get() com default ''
    // cobre docs que nunca tiveram o campo.
    function panelOwnerUnchanged() {
      return request.resource.data.get('panelOwnerId', '') == resource.data.get('panelOwnerId', '');
    }

    match /users/{userId} {
      // Membro lê o doc do dono para resolver nome/dados do painel compartilhado.
      allow get: if isOwner(userId) || isAdmin() || isMember(userId);
      allow list: if isAdmin();

      // Perfil sempre nasce como 'user'. O admin cria painéis e vincula membros;
      // o cliente cria o próprio perfil no primeiro login (Google/email) e NÃO pode
      // se auto-vincular a um painel — panelOwnerId só entra por escrita do admin.
      allow create: if isAdmin() ||
                       (isOwner(userId) && request.resource.data.role == 'user' &&
                        !('panelOwnerId' in request.resource.data));

      // O dono edita o próprio perfil, mas NÃO pode mexer no próprio `role` nem
      // se vincular a um painel. Só o admin altera papéis e vincula membros.
      allow update: if isAdmin() ||
                       (isOwner(userId) && roleUnchanged() && panelOwnerUnchanged());

      // Excluir um painel é ação administrativa.
      allow delete: if isAdmin();

      // Membro só LÊ o painel do dono; escrita e exclusão seguem restritas.
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin() || isMember(userId);
        allow delete: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read: if isOwner(userId) || isAdmin() || isMember(userId);
        allow delete: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
      }
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
