rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garante que o campo `role` não está sendo alterado nesta escrita.
    // request.resource.data = como o doc VAI ficar; resource.data = como ele ESTÁ hoje.
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    // Membro somente-leitura de um painel: o perfil do usuário logado aponta
    // (via panelOwnerId) para o dono `userId`. Custa um get(), por isso fica
    // sempre à direita dos || — isOwner/isAdmin resolvem primeiro.
    function isMember(userId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('panelOwnerId', '') == userId;
    }

    // Membro com permissão de ESCRITA no painel do dono `userId`. Só o admin marca
    // panelRole='editor' (garantido nas regras de users abaixo), então isto é o
    // gate que libera um membro a criar/editar/excluir dados do painel alheio.
    // Reusa o get() de isMember (cacheado na mesma avaliação).
    function isEditorMember(userId) {
      return isMember(userId) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('panelRole', '') == 'editor';
    }

    // O claim de panelOwnerId só é válido se existir um convite pendente para o
    // email do usuário E o painel do convite bater com o que ele quer gravar.
    // email_verified é obrigatório: sem isso, alguém poderia registrar o email
    // convidado (sem confirmar a caixa postal) e capturar o acesso ao painel.
    // Login Google já vem verificado; conta de senha precisa confirmar o email
    // antes do claim valer. Token sem email falha na avaliação e nega (fail closed).
    function claimMatchesInvite() {
      return request.auth.token.email_verified == true &&
             exists(/databases/$(database)/documents/invites/$(request.auth.token.email.lower())) &&
             get(/databases/$(database)/documents/invites/$(request.auth.token.email.lower())).data.panelOwnerId == request.resource.data.panelOwnerId;
    }

    // Impede que o usuário comum troque de painel sozinho num update. As exceções
    // são o admin (vincular direto) e o claim (primeiro login com convite válido).
    function panelOwnerUnchanged() {
      return request.resource.data.get('panelOwnerId', '') == resource.data.get('panelOwnerId', '');
    }

    // Impede o membro de se autopromover a editor. Só o admin muda panelRole.
    function panelRoleUnchanged() {
      return request.resource.data.get('panelRole', '') == resource.data.get('panelRole', '');
    }

    // O panelRole resultante é 'viewer' (ou ausente, que já é leitura). Usado para
    // garantir que TODO claim/self-create nasça somente leitura: editor é privilégio
    // que só o admin concede depois. Sem isso, um panelRole='editor' órfão (ex.: sobra
    // de um vínculo anterior) seria silenciosamente reativado ao entrar noutro painel.
    function newPanelRoleIsViewer() {
      return !('panelRole' in request.resource.data) ||
             request.resource.data.panelRole == 'viewer';
    }

    match /users/{userId} {
      // Membro lê o doc do dono para resolver o painel compartilhado.
      allow get: if isOwner(userId) || isAdmin() || isMember(userId);
      allow list: if isAdmin();

      // Perfil nasce como 'user'. O cliente cria o próprio no primeiro login e só
      // pode incluir panelOwnerId se houver um convite válido para o email (claim).
      // panelRole no self-create só pode nascer viewer/ausente: editor é privilégio
      // que só o admin concede, senão o claim viraria autopromoção.
      allow create: if isAdmin() ||
                       (isOwner(userId) && request.resource.data.role == 'user' &&
                        newPanelRoleIsViewer() &&
                        (!('panelOwnerId' in request.resource.data) || claimMatchesInvite()));

      // Não-admin só edita o próprio perfil em dois modos:
      //  A) mesmo painel: role E panelRole imutáveis (não se autopromove a editor);
      //  B) claim de convite: pode ganhar panelOwnerId, mas SEMPRE como viewer — um
      //     editor órfão de vínculo anterior não pode reativar em painel novo.
      // Admin passa direto por qualquer um dos campos.
      allow update: if isAdmin() ||
                       (isOwner(userId) && roleUnchanged() &&
                        ((panelOwnerUnchanged() && panelRoleUnchanged()) ||
                         (claimMatchesInvite() && newPanelRoleIsViewer())));

      allow delete: if isAdmin();

      // Membro lê o painel do dono; membro-editor também escreve. Dono e admin
      // mantêm o acesso de antes.
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin() || isMember(userId);
        allow delete: if isOwner(userId) || isAdmin() || isEditorMember(userId);
        allow create, update: if isOwner(userId) || isEditorMember(userId);
      }

      match /goals/{goalId} {
        allow read: if isOwner(userId) || isAdmin() || isMember(userId);
        allow delete: if isOwner(userId) || isAdmin() || isEditorMember(userId);
        allow create, update: if isOwner(userId) || isEditorMember(userId);
      }
    }

    // Convite pendente: o ID do doc é o email do convidado em minúsculas. O admin
    // cria/cancela; o convidado lê e deleta o PRÓPRIO convite ao reivindicá-lo no
    // login (grava panelOwnerId ANTES de deletar — claimMatchesInvite valida contra
    // o convite ainda existente). Serve tanto para login Google quanto por senha.
    match /invites/{inviteEmail} {
      // get sem email_verified de propósito: o app precisa detectar o convite no
      // login para pedir a verificação. Só vaza a existência do convite e o painel.
      allow get: if isAdmin() ||
                    (isSignedIn() && request.auth.token.email.lower() == inviteEmail);
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() ||
                       (isSignedIn() && request.auth.token.email_verified == true &&
                        request.auth.token.email.lower() == inviteEmail);
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
